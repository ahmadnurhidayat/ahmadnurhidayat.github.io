---
export interface Props {
  title: string;
  description: string;
  year: string;
  slug: string;
  image?: string;
  pinned?: boolean;
  tags?: string[];
  link?: string;
}

const { title, description, year, slug, image, pinned = false, tags = [], link } = Astro.props;
const hasImage = image && image.length > 0;
const displayTags = tags.slice(0, 4);
---

<a href={`/projects/${slug}`} class="group block bg-white dark:bg-neutral-900 border border-neutral-100 dark:border-neutral-800 rounded-card overflow-hidden transition-all duration-250 hover:border-neutral-300 dark:hover:border-neutral-600">
  <!-- Image — 4:3 editorial illustration pattern -->
  <div class="relative h-48 overflow-hidden bg-canvas-soft dark:bg-neutral-800">
    {hasImage ? (
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <svg class="w-12 h-12 text-neutral-200 dark:text-neutral-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    )}

    {pinned && (
      <span class="absolute top-3 right-3 text-[11px] font-bold bg-white dark:bg-neutral-900 text-black dark:text-white px-3 py-1.5 rounded-pill shadow-card">
        Pinned
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col">
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-caption text-ink-light dark:text-neutral-500">
        {year}
      </span>
      {link && (
        <span class="text-caption text-ink-light dark:text-neutral-500 opacity-0 group-hover:opacity-100 transition-opacity duration-250">
          View project &rarr;
        </span>
      )}
    </div>

    <h3 class="text-body-md-strong text-black dark:text-white group-hover:opacity-70 transition-opacity duration-250 leading-snug">
      {title}
    </h3>

    <p class="text-body-sm text-ink-body dark:text-neutral-400 mt-1.5 line-clamp-2">
      {description}
    </p>

    {displayTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-3">
        {displayTags.map((tag) => (
          <span class="text-[11px] font-medium bg-canvas-soft dark:bg-neutral-800 text-ink-mute dark:text-neutral-400 px-2.5 py-1 rounded-pill">
            {tag}
          </span>
        ))}
        {tags.length > 4 && (
          <span class="text-[11px] text-ink-light dark:text-neutral-500 self-center">+{tags.length - 4}</span>
        )}
      </div>
    )}
  </div>
</a>
