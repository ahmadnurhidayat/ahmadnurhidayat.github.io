---
export interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;
const displayTags = tags.slice(0, 3);
---

<a href={`/posts/${slug}`} class="group block bg-white dark:bg-neutral-900 border border-neutral-100 dark:border-neutral-800 rounded-card p-5 transition-all duration-250 hover:border-neutral-300 dark:hover:border-neutral-600 hover:shadow-card">
  <article class="flex flex-col h-full">
    <div class="flex items-center justify-between mb-3">
      <time class="text-caption text-ink-light dark:text-neutral-500 font-mono" datetime={date}>
        {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
      <svg class="w-4 h-4 text-ink-light dark:text-neutral-600 group-hover:text-black dark:group-hover:text-white group-hover:translate-x-0.5 transition-all duration-250" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </div>

    <h3 class="text-body-md-strong text-black dark:text-white group-hover:opacity-70 transition-opacity duration-250 leading-snug">
      {title}
    </h3>

    <p class="text-body-sm text-ink-body dark:text-neutral-400 mt-2 line-clamp-2 flex-1">
      {description}
    </p>

    {displayTags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mt-4">
        {displayTags.map((tag) => (
          <span class="text-[11px] font-medium bg-canvas-soft dark:bg-neutral-800 text-ink-mute dark:text-neutral-400 px-2.5 py-1 rounded-pill">
            {tag}
          </span>
        ))}
        {tags.length > 3 && (
          <span class="text-[11px] text-ink-light dark:text-neutral-500 self-center">+{tags.length - 3}</span>
        )}
      </div>
    )}
  </article>
</a>
