---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.pinned && !b.data.pinned) return -1;
    if (!a.data.pinned && b.data.pinned) return 1;
    return parseInt(b.data.year) - parseInt(a.data.year);
  });
---

<BaseLayout title="Projects | Ahmad Nurhidayat" description="Portfolio of DevOps and Cloud projects.">
  <section class="max-w-[900px] mx-auto px-4 sm:px-8 py-16">
    <div class="mb-12">
      <span class="text-[11px] font-medium text-ink-light dark:text-neutral-500 uppercase tracking-widest">Portfolio</span>
      <h1 class="text-[24px] md:text-[28px] font-bold text-black dark:text-white mt-2">Projects</h1>
      <p class="text-[14px] text-ink-body dark:text-neutral-400 mt-2 max-w-lg">
        Infrastructure and platform engineering work — from Kubernetes clusters to CI/CD pipelines and observability stacks.
      </p>
    </div>

    <div class="space-y-4">
      {projects.map((project, index) => (
        <a
          href={`/projects/${project.id.replace(/\.md$/, '')}`}
          class={`group flex flex-col md:flex-row gap-6 bg-white dark:bg-neutral-900 border border-neutral-100 dark:border-neutral-800 rounded-card overflow-hidden transition-all duration-250 hover:border-neutral-300 dark:hover:border-neutral-600 ${
            index % 2 === 1 ? 'md:flex-row-reverse' : ''
          }`}
        >
          {/* Image */}
          <div class="relative w-full md:w-72 h-48 md:h-auto shrink-0 overflow-hidden bg-canvas-soft dark:bg-neutral-800">
            {project.data.image && project.data.image.length > 0 ? (
              <img
                src={project.data.image}
                alt={project.data.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center min-h-[180px]">
                <svg class="w-12 h-12 text-neutral-200 dark:text-neutral-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
              </div>
            )}
            {project.data.pinned && (
              <span class="absolute top-3 right-3 text-[11px] font-bold bg-white dark:bg-neutral-900 text-black dark:text-white px-3 py-1.5 rounded-pill shadow-card">
                Pinned
              </span>
            )}
          </div>

          {/* Content */}
          <div class="flex-1 p-5 md:p-6 flex flex-col justify-center">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-[12px] font-mono text-ink-light dark:text-neutral-500">
                {project.data.year}
              </span>
              <svg class="w-4 h-4 text-ink-light dark:text-neutral-600 group-hover:text-black dark:group-hover:text-white transition-all duration-200 opacity-0 group-hover:opacity-100 group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>

            <h2 class="text-[16px] font-bold text-black dark:text-white group-hover:opacity-70 transition-opacity duration-250">
              {project.data.title}
            </h2>

            <p class="text-[13px] text-ink-body dark:text-neutral-400 mt-2 line-clamp-2">
              {project.data.description}
            </p>

            {project.data.tags && project.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-3">
                {project.data.tags.slice(0, 4).map(tag => (
                  <span class="text-[11px] font-medium text-ink-light dark:text-neutral-500 bg-canvas-soft dark:bg-neutral-800 px-2 py-0.5 rounded-md">
                    {tag}
                  </span>
                ))}
                {project.data.tags.length > 4 && (
                  <span class="text-[11px] text-ink-light dark:text-neutral-500 self-center">+{project.data.tags.length - 4}</span>
                )}
              </div>
            )}

            <div class="mt-4">
              <span class="btn-subtle text-[12px] inline-flex items-center gap-1.5">
                View project
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
